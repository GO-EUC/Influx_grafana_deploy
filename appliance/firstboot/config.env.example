# Optional fallback overrides read by /usr/local/bin/go-euc-firstboot.sh.
# In OVF-aware hypervisors, these are normally provided at OVA import time.

# Enable daily container image upgrades via systemd timer.
# AUTO_UPGRADE_ENABLED=true

# Optional appliance login override (if omitted, generated on first boot).
# APPLIANCE_LOGIN_USER=goeucadmin
# APPLIANCE_LOGIN_PASSWORD=goeucadmin

# Optional break-glass override (defaults are baked into image build).
# BREAK_GLASS_USER=recovery
# BREAK_GLASS_PASSWORD=Recover-ChangeMe-Now!

# Optional fallback network settings (usually set via OVA import properties).
# APPLIANCE_STATIC_IP_CIDR=192.168.1.50/24
# APPLIANCE_NETMASK=255.255.255.0
# APPLIANCE_GATEWAY=192.168.1.1
# APPLIANCE_DNS=1.1.1.1,8.8.8.8

# PORTAINER_ADMIN_USER=admin
# PORTAINER_ADMIN_PASSWORD=ChangeMeNow123!
# INFLUX_ADMIN_USER=influxadmin
# INFLUX_ADMIN_PASSWORD=ChangeMeNow123!
# INFLUX_ADMIN_ORG=monitoring
# INFLUX_INIT_BUCKET=bootstrap
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=ChangeMeNow123!
