#cloud-config
write_files:
  - path: /etc/go-euc/config.env
    permissions: "0644"
    content: |
      APPLIANCE_NAME=go-euc-appliance
      APPLIANCE_NET_IFACE=ens160
      APPLIANCE_STATIC_IP_CIDR=192.168.1.50/24
      APPLIANCE_GATEWAY=192.168.1.1
      APPLIANCE_DNS=1.1.1.1,8.8.8.8

runcmd:
  - [ systemctl, restart, go-euc-firstboot.service ]
